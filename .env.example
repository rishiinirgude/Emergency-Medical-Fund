# ── Stellar / Soroban ─────────────────────────────────────────────────────────

# Your Stellar deployer secret key (starts with S)
STELLAR_SECRET_KEY=S...

# Stellar RPC endpoint
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Deployed Contract IDs (fill after running scripts/deploy.sh) ──────────────
NEXT_PUBLIC_HOSPITAL_VERIFICATION_CONTRACT=C...
NEXT_PUBLIC_MEDICAL_FUND_CONTRACT=C...
NEXT_PUBLIC_CARE_TOKEN_CONTRACT=C...

# ── Optional ──────────────────────────────────────────────────────────────────
# Override demo hospital address for testnet seeding
DEMO_HOSPITAL_ADDRESS=G...
